{
	"license": "Apache-2.0",
	"scripts": {
		"dev": "mintlify dev",
		"hygiene:install": "curl -fsSL https://raw.githubusercontent.com/usecortex/mintlify-hygiene/main/install.sh | bash -s -- --dest ./bin",
		"hygiene": "(test -x ./bin/mintlify-hygiene || npm run hygiene:install) && ./bin/mintlify-hygiene check",
		"hygiene:strict": "(test -x ./bin/mintlify-hygiene || npm run hygiene:install) && ./bin/mintlify-hygiene check --deny-warnings"
	},
	"dependencies": {
		"mintlify": "^4.2.0"
	}
}
